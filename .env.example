# Database
DATABASE_URL=postgresql+asyncpg://ecscanner:secret@postgres:5432/ecscanner
DATABASE_URL_SYNC=postgresql+psycopg2://ecscanner:secret@postgres:5432/ecscanner

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# App
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Discovery APIs
SECURITYTRAILS_API_KEY=
VIRUSTOTAL_API_KEY=
RAPID7_DATA_DIR=/data/rapid7

# Enrichment APIs
CLEARBIT_API_KEY=
ZOOMINFO_API_KEY=
APOLLO_API_KEY=

# Outreach
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
OUTREACH_FROM_EMAIL=
OUTREACH_FROM_NAME=Inforge Security

# Salesforce CRM
SF_INSTANCE_URL=
SF_ACCESS_TOKEN=

# Scanner settings
SCAN_CONCURRENCY=10
SCAN_RATE_LIMIT_MS=2000
